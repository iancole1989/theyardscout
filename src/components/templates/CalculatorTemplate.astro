---
// Interactive calculator template.
// Based on Goldmine #2 (Gold IRA Calculator) — adapted for our higher-competition
// keyword targets. Accepts a `fields` array of inputs and a `formula` script that
// computes the output client-side.
//
// Each calculator article configures fields + formula + interpretation tiers.
// The interpretation tiers map the computed output to qualitative messages
// ("excellent", "marginal", "needs work") + tier-specific CTAs.
//
// Usage:
//   <CalculatorTemplate
//     title="DSCR Ratio Calculator"
//     formulaId="dscr-ratio"
//     fields={[
//       { id: "rent", label: "Monthly rental income", suffix: "$", type: "number", default: 2500 },
//       { id: "piti", label: "Monthly PITI (mortgage + tax + insurance)", suffix: "$", type: "number", default: 1800 },
//     ]}
//     formula={`(values) => values.piti > 0 ? values.rent / values.piti : 0`}
//     outputLabel="Your DSCR ratio"
//     outputFormat="number"
//     outputDecimals={2}
//     tiers={[
//       { min: 1.25, label: "Excellent — qualifies for most DSCR programs at best rates", cta: "...", ctaHref: "..." },
//       { min: 1.0, label: "Marginal — some lenders, expect higher rates", cta: "...", ctaHref: "..." },
//       { min: 0, label: "Below 1.0 — most lenders will pass; consider re-evaluating", cta: "...", ctaHref: "..." },
//     ]}
//   >
//     ...article body explaining what DSCR is, why it matters, examples, etc.
//   </CalculatorTemplate>

export interface CalcField {
  id: string;
  label: string;
  type: "number" | "currency" | "percent";
  default?: number;
  suffix?: string;
  min?: number;
  max?: number;
  step?: number;
}

export interface CalcTier {
  min: number;
  label: string;
  cta?: string;
  ctaHref?: string;
}

export interface Props {
  title: string;
  formulaId: string;
  fields: CalcField[];
  formula: string; // JavaScript arrow function as string: "(values) => values.x / values.y"
  outputLabel: string;
  outputFormat?: "number" | "currency" | "percent";
  outputDecimals?: number;
  tiers?: CalcTier[];
  ctaDefaultLabel?: string;
  ctaDefaultHref?: string;
}

const {
  title,
  formulaId,
  fields,
  formula,
  outputLabel,
  outputFormat = "number",
  outputDecimals = 2,
  tiers = [],
  ctaDefaultLabel,
  ctaDefaultHref,
} = Astro.props;
---

<div class="calculator-template my-8">
  <section class="bg-canvas-subtle border border-line rounded-md p-5 md:p-7">
    <h2 class="font-heading font-bold text-2xl text-slate-deep mb-1">{title}</h2>
    <p class="text-sm text-caution mb-5">Update the values below. Result and recommendation update live.</p>

    <form id={`calc-${formulaId}`} class="space-y-4">
      {fields.map((f) => (
        <div class="flex flex-col md:flex-row md:items-center gap-2 md:gap-4">
          <label
            for={`${formulaId}-${f.id}`}
            class="md:w-72 font-semibold text-slate-deep text-sm"
          >
            {f.label}
            {f.suffix && <span class="text-caution font-normal ml-1">({f.suffix})</span>}
          </label>
          <input
            type="number"
            id={`${formulaId}-${f.id}`}
            name={f.id}
            value={f.default ?? 0}
            min={f.min}
            max={f.max}
            step={f.step ?? "any"}
            class="flex-1 px-3 py-2 rounded-md border border-line bg-canvas-white text-slate-deep focus:outline-none focus:ring-2 focus:ring-teal"
          />
        </div>
      ))}
    </form>

    <div class="mt-6 pt-5 border-t border-line">
      <div class="flex flex-wrap items-baseline gap-3">
        <span class="font-semibold text-slate-deep">{outputLabel}:</span>
        <span
          id={`${formulaId}-output`}
          class="font-num font-extrabold text-3xl md:text-4xl text-teal"
        >—</span>
      </div>
      <p
        id={`${formulaId}-tier`}
        class="mt-3 text-slate-charcoal leading-relaxed"
      ></p>
      <a
        id={`${formulaId}-cta`}
        href="#"
        class="hidden inline-flex items-center mt-3 px-5 py-2.5 rounded-md font-semibold text-sm bg-teal text-white hover:bg-teal-hover no-underline transition-colors"
        rel="sponsored noopener noreferrer"
        target="_blank"
        data-cta-type="calculator-tier-cta"
      ></a>
    </div>
  </section>

  <slot />
</div>

<script is:inline define:vars={{ formulaId, formula, fields, tiers, outputFormat, outputDecimals, ctaDefaultLabel, ctaDefaultHref }}>
  (function () {
    const form = document.getElementById(`calc-${formulaId}`);
    const outputEl = document.getElementById(`${formulaId}-output`);
    const tierEl = document.getElementById(`${formulaId}-tier`);
    const ctaEl = document.getElementById(`${formulaId}-cta`);
    if (!form || !outputEl) return;

    const fn = new Function("return (" + formula + ")")();

    const format = (n) => {
      if (!isFinite(n) || isNaN(n)) return "—";
      const opts = { maximumFractionDigits: outputDecimals, minimumFractionDigits: outputDecimals };
      if (outputFormat === "currency") return n.toLocaleString("en-US", { style: "currency", currency: "USD", ...opts });
      if (outputFormat === "percent") return (n * 100).toLocaleString("en-US", opts) + "%";
      return n.toLocaleString("en-US", opts);
    };

    const recompute = () => {
      const values = {};
      fields.forEach((f) => {
        const el = document.getElementById(`${formulaId}-${f.id}`);
        values[f.id] = el ? parseFloat(el.value) || 0 : 0;
      });

      let result;
      try { result = fn(values); } catch (e) { result = NaN; }

      outputEl.textContent = format(result);

      const sorted = (tiers || []).slice().sort((a, b) => b.min - a.min);
      const matched = sorted.find((t) => result >= t.min);

      if (matched) {
        tierEl.textContent = matched.label;
        if (matched.cta && matched.ctaHref) {
          ctaEl.href = matched.ctaHref;
          ctaEl.textContent = matched.cta;
          ctaEl.classList.remove("hidden");
        } else if (ctaDefaultLabel && ctaDefaultHref) {
          ctaEl.href = ctaDefaultHref;
          ctaEl.textContent = ctaDefaultLabel;
          ctaEl.classList.remove("hidden");
        } else {
          ctaEl.classList.add("hidden");
        }
      } else {
        tierEl.textContent = "";
        ctaEl.classList.add("hidden");
      }
    };

    form.addEventListener("input", recompute);
    recompute();
  })();
</script>
