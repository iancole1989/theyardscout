---
import { SITE } from "@/lib/site";

export interface Props {
  author?: string;
  updated?: Date;
}

const { author = SITE.author, updated } = Astro.props;
---

<aside class="my-10 border-t border-line pt-6 flex items-start gap-4">
  <div class="w-12 h-12 bg-teal rounded-md flex-shrink-0 flex items-center justify-center font-heading font-extrabold text-canvas-white">
    Y
  </div>
  <div>
    <p class="font-semibold text-slate-deep">{author}</p>
    <p class="text-sm text-caution mt-1 leading-relaxed">
      We write for backyard-wellness buyers — people choosing hot tubs, saunas, and cold plunges. Every
      spec and price is checked against the manufacturer source. Affiliate recommendations are tested
      against owner usability — not commission size. See our{" "}
      <a href="/editorial-standards" class="underline text-teal">editorial standards</a>.
    </p>
    {
      updated && (
        <p class="text-xs text-caution mt-2">
          Last reviewed: {updated.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
        </p>
      )
    }
  </div>
</aside>
