---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact"
  description="Get in touch with the The Yard Scout team."
>
  <section class="container-article py-12 md:py-16">
    <h1 class="font-heading font-extrabold text-4xl md:text-5xl text-slate-deep tracking-tight">
      Contact.
    </h1>

    <div class="prose prose-lg max-w-none mt-6">
      <p>
        Editorial corrections, affiliate inquiries, partnership questions, or general feedback —
        we read everything that comes in.
      </p>
      <p>
        Email:{" "}
        <a href="mailto:hello@theyardscout.com">hello@theyardscout.com</a>
      </p>
      <p class="text-sm text-caution">
        We aim to respond within 5 business days. We don't offer specific medical, electrical, or
        installation advice over email — for those situations, talk to a licensed professional.
      </p>
    </div>
  </section>
</BaseLayout>
