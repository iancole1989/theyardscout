---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import AuthorBox from "@/components/AuthorBox.astro";
import AffiliateDisclosure from "@/components/AffiliateDisclosure.astro";
import { SITE } from "@/lib/site";

export interface Props {
  title: string;
  description: string;
  slug: string;
  publishedAt: Date;
  updated: Date;
  author?: string;
  heroImage?: string;
  heroImageAlt?: string;
  schemaType?: "Article" | "HowTo" | "Review" | "FAQPage";
  isComparison?: boolean;
}

const {
  title,
  description,
  slug,
  publishedAt,
  updated,
  author = SITE.author,
  heroImage,
  heroImageAlt,
  schemaType = "Article",
  isComparison = false,
} = Astro.props;

const articleUrl = new URL(`/llc-guide/${slug}`, SITE.url).toString();

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": schemaType,
  headline: title,
  description,
  datePublished: publishedAt.toISOString(),
  dateModified: updated.toISOString(),
  author: {
    "@type": "Organization",
    name: author,
    url: SITE.url,
  },
  publisher: {
    "@type": "Organization",
    name: SITE.name,
    url: SITE.url,
  },
  mainEntityOfPage: { "@type": "WebPage", "@id": articleUrl },
  ...(heroImage && { image: heroImage.startsWith("http") ? heroImage : new URL(heroImage, SITE.url).toString() }),
};
---

<BaseLayout
  title={title}
  description={description}
  ogType="article"
  ogImage={heroImage}
  publishedAt={publishedAt}
  updatedAt={updated}
  jsonLd={articleJsonLd}
>
  <article class="container-article py-10 md:py-14">
    <Breadcrumbs
      items={[
        { label: "Home", href: "/" },
        { label: "LLC Guides", href: "/" },
        { label: title },
      ]}
    />

    <header class="mb-8">
      <h1 class="font-heading font-extrabold text-3xl md:text-4xl lg:text-[2.5rem] leading-tight text-slate-deep tracking-tight">
        {title}
      </h1>
      <div class="mt-4 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-caution">
        <span>{author}</span>
        <span class="text-line">·</span>
        <span>
          Updated{" "}
          {updated.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
        </span>
      </div>
    </header>

    {
      heroImage && (
        <img
          src={heroImage}
          alt={heroImageAlt ?? ""}
          class="rounded-md w-full mb-8"
          loading="eager"
        />
      )
    }

    <AffiliateDisclosure variant="inline" />

    <div class="prose prose-base md:prose-lg max-w-none">
      <slot />
    </div>

    <AuthorBox author={author} updated={updated} />
  </article>
</BaseLayout>
